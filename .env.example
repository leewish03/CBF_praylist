# ============================
# CBF 기도제목 자동화 V2
# 환경 변수 예시 파일 (.env.example)
# 실제 값으로 교체하여 .env 파일로 사용하세요
# ============================

# Google Sheets 설정
SPREADSHEET_ID=your_google_spreadsheet_id
RESPONSES_SPREADSHEET_ID=your_responses_spreadsheet_id
RANGE_NAME='설문지 응답 시트1'!A:Z
SERVICE_ACCOUNT_FILE=your_service_account_file.json

# Notion 설정 (선택 사항 - API 서버만 사용 시 불필요)
NOTION_TOKEN=your_notion_integration_token
NOTION_PAGE_ID=your_notion_page_id

# 로깅 설정
LOG_LEVEL=INFO
LOG_FILE=prayer_pipeline.log
LOG_MAX_SIZE_MB=10
LOG_BACKUP_COUNT=5

# 서버 포트 (Render.com이 자동 설정하므로 주석 처리)
# PORT=8000
